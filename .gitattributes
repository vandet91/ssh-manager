# Force LF line endings for all text files in the repo.
# This ensures files work correctly when deployed inside Linux Docker containers,
# regardless of what OS the developer is using.

* text=auto eol=lf

# Explicitly LF for these types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env* text eol=lf
*.sh   text eol=lf
*.conf text eol=lf
*.sql  text eol=lf
Dockerfile text eol=lf

# Binary — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
